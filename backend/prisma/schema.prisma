datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relacionamento: Um usuário pode ter vários veículos
  vehicles  Vehicle[]

  @@map("users")
}


model Vehicle {
  id              String   @id @default(uuid())
  brand           String
  model           String
  year            Int
  batteryCapacity Float    // Capacidade da bateria em kWh (ex: 75.0)
  licensePlate    String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relacionamento com a tabela de Usuário
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vehicles")
}